// PPS Jobs - Complete Job Portal Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// User Model - Base authentication model
model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  mobile        String?   @unique
  password      String
  role          String
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  employer      Employer?
  jobSeeker     JobSeeker?
}

// Employer Model - Company and employer details
model Employer {
  id                    String       @id @default(cuid())
  userId                String       @unique
  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName           String
  companyLocation       String
  companyAddress        String?
  companyDomain         String?
  spocName              String
  mobile                String
  employeeCount         String?

  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  credits               Credit[]
  creditTransactions    CreditTransaction[]
  jobs                  Job[]
  unlocks               Unlock[]
}

// Job Seeker Model - Candidate details
model JobSeeker {
  id                    String       @id @default(cuid())
  userId                String       @unique
  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName              String
  email                 String?
  mobile                String
  currentLocation       String
  preferredLocation     String?
  employmentType        String
  profileCompletion     Int          @default(0)

  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  experiences           Experience[]
  skills                Skill[]
  applications          Application[]
  unlocks               Unlock[]
}

// Experience Model - Work experience (max 5 per job seeker)
model Experience {
  id                    String       @id @default(cuid())
  jobSeekerId           String
  jobSeeker             JobSeeker    @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade)

  companyName           String
  designation           String
  lastSalary            String?
  dateOfJoining         DateTime?
  lastWorkingDate       DateTime?
  currentlyWorking      Boolean      @default(false)

  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@index([jobSeekerId])
}

// Skill Model - Job Seeker skills
model Skill {
  id                    String       @id @default(cuid())
  jobSeekerId           String
  jobSeeker             JobSeeker    @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade)

  name                  String

  createdAt             DateTime     @default(now())

  @@index([jobSeekerId])
}

// Credit Model - Employer credits with expiry
model Credit {
  id                    String       @id @default(cuid())
  employerId            String
  employer              Employer     @relation(fields: [employerId], references: [id], onDelete: Cascade)

  balance               Int          @default(0)
  expiryDate            DateTime?
  isFreeCreditsUsed     Boolean      @default(false)

  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  transactions          CreditTransaction[]

  @@index([employerId])
}

// Credit Transaction Model - Track credit additions/deductions
model CreditTransaction {
  id                    String       @id @default(cuid())
  creditId              String
  credit                Credit       @relation(fields: [creditId], references: [id], onDelete: Cascade)
  employerId            String
  employer              Employer     @relation(fields: [employerId], references: [id], onDelete: Cascade)

  type                  String
  amount                Int
  description           String?
  referenceId           String?

  createdAt             DateTime     @default(now())

  @@index([creditId])
  @@index([employerId])
  @@index([createdAt])
}

// Job Model - Job postings
model Job {
  id                    String       @id @default(cuid())
  employerId            String
  employer              Employer     @relation(fields: [employerId], references: [id], onDelete: Cascade)

  title                 String
  description           String?
  location              String
  requirements          String?
  salary                String?
  experienceRequired    String?
  isActive              Boolean      @default(true)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  applications          Application[]

  @@index([employerId])
  @@index([isActive])
  @@index([createdAt])
}

// Application Model - Job applications
model Application {
  id                    String       @id @default(cuid())
  jobId                 String
  job                   Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)

  jobSeekerId           String
  jobSeeker             JobSeeker    @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade)

  status                String       @default("applied")
  createdAt             DateTime     @default(now())

  @@unique([jobId, jobSeekerId])
  @@index([jobId])
  @@index([jobSeekerId])
}

// Unlock Model - Track profile unlocks by employers
model Unlock {
  id                    String       @id @default(cuid())
  employerId            String
  employer              Employer     @relation(fields: [employerId], references: [id], onDelete: Cascade)

  jobSeekerId           String
  jobSeeker             JobSeeker    @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade)

  createdAt             DateTime     @default(now())

  @@unique([employerId, jobSeekerId])
  @@index([employerId])
  @@index([jobSeekerId])
}
